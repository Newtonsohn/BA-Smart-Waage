@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager Navigation
<div class="page">
    <div style="width: 250px; background-color: dimgrey">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <NotAuthorized>
                    <button class="btn btn-primary" @onclick="Login">Login</button>
                </NotAuthorized>
                <Authorized>
                    <form method="post" action="/authentication/logout">
                        <button type="submit" class="btn btn-secondary">Logout</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
<BlazoredToasts />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private void Login()
    {
        // Navigate to your login endpoint. forceLoad:true triggers a full page reload.
        Navigation.NavigateTo("/authentication/login", forceLoad: true);
    }

    private void Logout()
    {
        // Navigate to your logout endpoint.
        Navigation.NavigateTo("/authentication/logout", forceLoad: true);
    }
}