@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager

<div class="nav-scrollable" style="background-color: rgba(13, 110, 253, 0.1);">
    <nav class="nav flex-column">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link d-flex align-items-center" href="" Match="NavLinkMatch.All">
                <Icon Name="IconName.House" Size="IconSize.x5" class="me-2" /> Home
            </NavLink>
        </div>

        <!-- System Section -->
        <AuthorizeView Policy="AtLeastManager">
            <Authorized Context="managerContext">
                <div class="nav-item px-3">
                    <button class="nav-link d-flex align-items-center w-100 text-start collapsed"
                            data-bs-toggle="collapse" data-bs-target="#systemMenu" aria-expanded="false">
                        <Icon Name="IconName.GearFill" Size="IconSize.x5" class="me-2" /> System
                    </button>

                    <div class="collapse ps-3" id="systemMenu">
                        <AuthorizeView Policy="AtLeastSystemAdministrator" Context="adminContext">
                            <Authorized>
                                <div class="nav-item px-3">
                                    <NavLink class="nav-link d-flex align-items-center" href="/systemoverview">
                                        <Icon Name="IconName.Sliders" Size="IconSize.x5" class="me-2" /> Configuration
                                    </NavLink>
                                </div>
                            </Authorized>
                        </AuthorizeView>

                        <div class="nav-item px-3">
                            <NavLink class="nav-link d-flex align-items-center" href="/bins/availability">
                                <Icon Name="IconName.HddNetwork" Size="IconSize.x5" class="me-2" />Overview
                            </NavLink>
                        </div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- Inventory Section -->
        <AuthorizeView Policy="AtLeastEmployee">
            <Authorized Context="employeeContext">
                <div class="nav-item px-3">
                    <button class="nav-link d-flex align-items-center w-100 text-start collapsed"
                            data-bs-toggle="collapse" data-bs-target="#inventoryMenu" aria-expanded="false">
                        <Icon Name="IconName.BoxSeam" Size="IconSize.x5" class="me-2" /> Inventory
                    </button>

                    <div class="collapse ps-3" id="inventoryMenu">
                        <AuthorizeView Policy="AtLeastManager" Context="managerContext2">
                            <Authorized>
                                <div class="nav-item px-3">
                                    <NavLink class="nav-link d-flex align-items-center" href="/inventory/items">
                                        <Icon Name="IconName.ListTask" Size="IconSize.x5" class="me-2" /> Items
                                    </NavLink>
                                </div>
                                <div class="nav-item px-3">
                                    <NavLink class="nav-link d-flex align-items-center" href="/inventory/dashboard">
                                        <Icon Name="IconName.GraphDown" Size="IconSize.x5" class="me-2" /> Analyse
                                    </NavLink>
                                </div>
                            </Authorized>
                        </AuthorizeView>

                        <NavLink class="nav-link d-flex align-items-center gap-2" href="/inventory/search">
                            <Icon Name="IconName.Search" Size="IconSize.x5" class="me-2" />
                            <span>Search</span>
                        </NavLink>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>


    </nav>
</div>



