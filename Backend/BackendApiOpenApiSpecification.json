{
  "openapi": "3.0.1",
  "info": {
    "title": "Backend.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://[::]:5001"
    },
    {
      "url": "https://[::]:7093"
    }
  ],
  "paths": {
    "/authentication/login": {
      "get": {
        "tags": [
          "LoginLogoutEdnpointRouteBuilderExensions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/authentication/logout": {
      "post": {
        "tags": [
          "LoginLogoutEdnpointRouteBuilderExensions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/bins/configuration": {
      "get": {
        "tags": [
          "BinEndpoints"
        ],
        "summary": "Get bin configuration",
        "description": "Retrieves the configuration for a bin using its MAC address. Requires Gateway authorization.",
        "parameters": [
          {
            "name": "macAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BinResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bins/networkConfiguration": {
      "get": {
        "tags": [
          "BinEndpoints"
        ],
        "summary": "Get network configuration",
        "description": "Retrieves the network configuration for a bin using its MAC address. Requires Gateway authorization.",
        "parameters": [
          {
            "name": "macAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BinResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bins/currentweight": {
      "put": {
        "tags": [
          "BinEndpoints"
        ],
        "summary": "Update bin weight",
        "description": "Updates the current weight of a bin. Used by smart bins to report weight changes. Requires Gateway authorization.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBinWeightCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/gateways/register": {
      "put": {
        "tags": [
          "GatewayEndpoints"
        ],
        "summary": "Register a gateway",
        "description": "Registers a gateway device. Returns 201 if created, 200 if already registered, 304 on conflict, 400 on validation error, or 500 on server error.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterGatewayCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "200": {
            "description": "OK"
          },
          "304": {
            "description": "Not Modified"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/gateways/assignedBins": {
      "get": {
        "tags": [
          "GatewayEndpoints"
        ],
        "summary": "Get assigned bins for a gateway",
        "description": "Retrieves bin MAC addresses assigned to a gateway by its MAC address.",
        "parameters": [
          {
            "name": "mac",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/inventory/article/{itemNumber}": {
      "get": {
        "tags": [
          "InventoryEndopints"
        ],
        "summary": "Get inventory by item number",
        "description": "Retrieves inventory details for a specific item number. Optional 'showDetails' query flag controls detail level.",
        "parameters": [
          {
            "name": "itemNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "showDetails",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InventoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/inventory/bin/{smartBinId}": {
      "get": {
        "tags": [
          "InventoryEndopints"
        ],
        "summary": "Get bin inventory by bin ID",
        "description": "Retrieves inventory for a specific smart bin ID. The ID must be a valid GUID.",
        "parameters": [
          {
            "name": "smartBinId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BinInventoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/inventory/bins": {
      "get": {
        "tags": [
          "InventoryEndopints"
        ],
        "summary": "Get all bin summaries",
        "description": "Retrieves inventory summaries for all available bins.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BinInventoryResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BinInventoryResponse": {
        "type": "object",
        "properties": {
          "binName": {
            "type": "string"
          },
          "itemName": {
            "type": "string"
          },
          "itemNumber": {
            "type": "string"
          },
          "currentWeight": {
            "type": "number",
            "format": "double"
          },
          "itemCount": {
            "type": "integer",
            "format": "int32"
          },
          "itemWeight": {
            "type": "number",
            "format": "double"
          },
          "fillLevel": {
            "type": "number",
            "format": "double"
          },
          "indicator": {
            "$ref": "#/components/schemas/StockIndicator"
          },
          "isEmpty": {
            "type": "boolean"
          }
        }
      },
      "BinResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "treshold": {
            "type": "number",
            "format": "double"
          },
          "capacity": {
            "type": "number",
            "format": "double"
          },
          "updateInterval": {
            "type": "integer",
            "format": "int32"
          },
          "heartBeatInterval": {
            "type": "integer",
            "format": "int32"
          },
          "inventoryItem": {
            "$ref": "#/components/schemas/InventoryItemResponse"
          }
        }
      },
      "InventoryItemResponse": {
        "required": [
          "id",
          "itemName",
          "itemNumber",
          "itemWeight"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "itemName": {
            "type": "string"
          },
          "itemNumber": {
            "type": "string"
          },
          "itemWeight": {
            "type": "number",
            "format": "double"
          }
        },
        "nullable": true
      },
      "InventoryResponse": {
        "required": [
          "itemNumber",
          "totalWeight",
          "itemCount",
          "inventoryFillLevel",
          "bins"
        ],
        "type": "object",
        "properties": {
          "itemNumber": {
            "type": "string"
          },
          "totalWeight": {
            "type": "number",
            "format": "double"
          },
          "itemCount": {
            "type": "integer",
            "format": "int32"
          },
          "inventoryFillLevel": {
            "type": "number",
            "format": "double"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BinInventoryResponse"
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RegisterGatewayCommand": {
        "required": [
          "macAddress",
          "ipAddress"
        ],
        "type": "object",
        "properties": {
          "macAddress": {
            "type": "string"
          },
          "ipAddress": {
            "type": "string"
          }
        }
      },
      "StockIndicator": {
        "type": "integer"
      },
      "UpdateBinWeightCommand": {
        "required": [
          "currentWeight",
          "macAddress"
        ],
        "type": "object",
        "properties": {
          "currentWeight": {
            "type": "number",
            "format": "float"
          },
          "macAddress": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "LoginLogoutEdnpointRouteBuilderExensions"
    },
    {
      "name": "BinEndpoints"
    },
    {
      "name": "GatewayEndpoints"
    },
    {
      "name": "InventoryEndopints"
    }
  ]
}